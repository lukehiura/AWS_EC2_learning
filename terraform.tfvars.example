# aws_region         = "us-east-1"
# instance_type      = "t2.micro"   # or t3.micro if t2 unavailable in region
# root_volume_size_gb = 8
# instance_name      = "learning-ec2"
# key_name           = "learning-ec2-key"

# Lock SSH to your IP (recommended):
# allowed_ssh_cidr   = "203.0.113.50/32"

# Use your own public key instead of Terraform-generated PEM in state:
# ssh_public_key     = file("~/.ssh/id_ed25519.pub")

# GitHub Actions OIDC role (requires GitHub OIDC provider already in the account)
# create_github_actions_ci_role   = false
# github_actions_repository       = "lukehiura/AWS_EC2_learning"
# github_actions_role_name        = "github-actions-ec2"
